### ── Management (Full CRUD) ──────────────────────────────

# @name listStudents
# Filter:  status | academic_year | gender | blood_group
# Search:  first_name | last_name | admission_number | roll_number | primary_contact_number
# Order:   created_at | admission_date | first_name
GET {{baseUrl}}/students/management/?status=active&gender=male&ordering=-created_at
Content-Type: {{contentType}}

###

# @name createStudent
POST {{baseUrl}}/students/management/
Content-Type: {{contentType}}

{
  "first_name": "Karim",
  "last_name": "Hossain",
  "admission_number": "ADM-2025-001",
  "roll_number": "101",
  "gender": "male",
  "blood_group": "O+",
  "status": "active",
  "academic_year": 1,
  "admission_date": "2025-01-15",
  "primary_contact_number": "01712345678"
}

###

# @name getStudent
GET {{baseUrl}}/students/management/1/
Content-Type: {{contentType}}

###

# @name updateStudent
PATCH {{baseUrl}}/students/management/1/
Content-Type: {{contentType}}

{
  "status": "inactive"
}

###

# @name deleteStudent
DELETE {{baseUrl}}/students/management/1/
Content-Type: {{contentType}}

