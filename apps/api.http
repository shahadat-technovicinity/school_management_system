###  Router: class-sections | sections | academic-years | class-rooms
### ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# @name listAcademicYears
GET {{baseUrl}}/academics/academic-years/
Content-Type: {{contentType}}

###

# @name createAcademicYear
POST {{baseUrl}}/academics/academic-years/
Content-Type: {{contentType}}

{
  "name": "2025-2026",
  "start_date": "2025-01-01",
  "end_date": "2025-12-31",
  "is_current": true
}

###

# @name getAcademicYear
GET {{baseUrl}}/academics/academic-years/1/
Content-Type: {{contentType}}

###

# @name updateAcademicYear
PATCH {{baseUrl}}/academics/academic-years/1/
Content-Type: {{contentType}}

{
  "is_current": false
}

###

# @name deleteAcademicYear
DELETE {{baseUrl}}/academics/academic-years/1/
Content-Type: {{contentType}}

