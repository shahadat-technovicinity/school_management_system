# @name listEnrollments
# Filter: student | course | status | term
# Search: student__first_name | student__last_name | course__title
# Order:  created_at | updated_at | start_date | end_date
GET {{baseUrl}}/enrollments/enrollments/?status=active&ordering=-created_at
Content-Type: {{contentType}}

###

# @name createEnrollment
POST {{baseUrl}}/enrollments/enrollments/
Content-Type: {{contentType}}

{
  "student": 1,
  "course": 1,
  "status": "active",
  "term": "2025-1",
  "start_date": "2025-01-15",
  "end_date": "2025-06-30"
}

###

# @name getEnrollment
GET {{baseUrl}}/enrollments/enrollments/1/
Content-Type: {{contentType}}

###

# @name updateEnrollment
PATCH {{baseUrl}}/enrollments/enrollments/1/
Content-Type: {{contentType}}

{
  "status": "completed"
}

###

# @name deleteEnrollment
DELETE {{baseUrl}}/enrollments/enrollments/1/
Content-Type: {{contentType}}


