### ============================================================
###  School Management System — apps/ REST Client
###  Compatible with: VS Code REST Client · JetBrains HTTP Client
### ============================================================

@baseUrl = http://127.0.0.1:8000
@contentType = application/json

### ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
