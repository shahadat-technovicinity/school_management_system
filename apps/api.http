### ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
###  ADMISSIONS  →  /admissions/
###  Router: forms | lottery | completion
###  Custom: bulk-import/
### ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# @name listAdmissionForms
# Filter params: admission_status | desired_class | payment_status
# Search:        student_name_english | application_number | mobile_number
GET {{baseUrl}}/admissions/forms/?admission_status=pending
Content-Type: {{contentType}}

###

# @name createAdmissionForm
POST {{baseUrl}}/admissions/forms/
Content-Type: {{contentType}}

{
  "student_name_english": "Rahim Uddin",
  "mobile_number": "01712345678",
  "desired_class": 1,
  "admission_status": "pending",
  "payment_status": "unpaid"
}

###

# @name getAdmissionForm
GET {{baseUrl}}/admissions/forms/1/
Content-Type: {{contentType}}

###

# @name updateAdmissionForm
PATCH {{baseUrl}}/admissions/forms/1/
Content-Type: {{contentType}}

{
  "payment_status": "paid"
}

###

# @name deleteAdmissionForm
DELETE {{baseUrl}}/admissions/forms/1/
Content-Type: {{contentType}}

###

# @name changeAdmissionStatus
# Custom action: PATCH /admissions/forms/{id}/change_status/
PATCH {{baseUrl}}/admissions/forms/1/change_status/
Content-Type: {{contentType}}

{
  "status": "selected"
}

###

# @name bulkImportAdmissions
# Accepts multipart: file (CSV/Excel) + class_id + section_id
POST {{baseUrl}}/admissions/bulk-import/
Content-Type: multipart/form-data; boundary=----Boundary

------Boundary
Content-Disposition: form-data; name="file"; filename="students.csv"
Content-Type: text/csv

< ./students_sample.csv
------Boundary
Content-Disposition: form-data; name="class_id"

class 6
------Boundary
Content-Disposition: form-data; name="section_id"

A
------Boundary--

###
### ── Lottery ──────────────────────────────────────────────

# @name lotteryStats
# Query param: class (default "class 6")
GET {{baseUrl}}/admissions/lottery/stats/?class=class%206
Content-Type: {{contentType}}

###

# @name lotteryAssignNumbers
POST {{baseUrl}}/admissions/lottery/assign_numbers/
Content-Type: {{contentType}}

{
  "class": "class 6"
}

###

# @name lotteryExecute
POST {{baseUrl}}/admissions/lottery/execute/
Content-Type: {{contentType}}

{
  "class": "class 6",
  "seats": 100
}

###
### ── Completion ───────────────────────────────────────────

# @name listSelectedApplicants
# Shows only applicants with status = 'selected'
GET {{baseUrl}}/admissions/completion/
Content-Type: {{contentType}}

###

# @name getCompletion
GET {{baseUrl}}/admissions/completion/1/
Content-Type: {{contentType}}

###

# @name finalizeAdmission
# Multipart: Provide TC / NID / Photo files
POST {{baseUrl}}/admissions/completion/1/finalize/
Content-Type: multipart/form-data; boundary=----FileBoundary

------FileBoundary
Content-Disposition: form-data; name="tc"; filename="tc.pdf"
Content-Type: application/pdf

< ./tc.pdf
------FileBoundary--


### ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
###  ATTENDANCE  →  /attendance/
###  Endpoints: bulk/ | patch/ | student/{id}/
### ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# @name bulkMarkAttendance
# Auth required
POST {{baseUrl}}/attendance/bulk/
Content-Type: {{contentType}}

{
  "class_section": 1,
  "date": "2025-07-04",
  "records": [
    { "student": 1, "status": "present" },
    { "student": 2, "status": "absent" },
    { "student": 3, "status": "late" }
  ]
}

###

# @name patchAttendanceByKey
# Patch a single record identified by student + class_section + date
PATCH {{baseUrl}}/attendance/patch/
Content-Type: {{contentType}}

{
  "student": 1,
  "class_section": 1,
  "date": "2025-07-04",
  "status": "present"
}

###

# @name studentAttendanceList
# Query params: class_section | marked_by | date
GET {{baseUrl}}/attendance/student/1/?date=2025-07-04
Content-Type: {{contentType}}


